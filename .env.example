# PostgreSQL
POSTGRES_DB=booking_db
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
CONNECTION_STRING=Host=postgres;Port=5432;Database=booking_db;Username=booking_user;Password=CHANGE_ME

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET_KYC=kyc-documents
MINIO_BUCKET_PROPERTIES=property-photos
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=CHANGE_ME

# Gemini AI (KYC processing)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

# SMTP / Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=noreply@bookingapp.com

# JWT
JWT_SECRET=CHANGE_ME_min_32_chars
JWT_ISSUER=BookingApp
JWT_AUDIENCE=BookingAppUsers
JWT_EXPIRY_MINUTES=60

# JWT Refresh Token
JWT_REFRESH_SECRET=CHANGE_ME_min_32_chars
JWT_REFRESH_EXPIRY_DAYS=7

# App
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080
